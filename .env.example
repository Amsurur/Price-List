# Copy to .env and adjust. Never commit .env.

# --- Postgres (used by docker-compose and the API) ---
# Port 5433 (not 5432) to avoid clashing with a local Postgres you may already run.
DB_HOST=localhost
DB_PORT=5433
DB_USER=softclub
DB_PASSWORD=softclub
DB_NAME=softclub_store
# Alternatively a single URL (TypeORM will use this if set):
DATABASE_URL=postgres://softclub:softclub@localhost:5433/softclub_store

# --- Ports ---
API_PORT=3001
WEB_PORT=3000

# --- Web (Next.js public vars) ---
NEXT_PUBLIC_API_URL=http://localhost:3001/api
NEXT_PUBLIC_CURRENCY=$

# --- API CORS ---
WEB_ORIGIN=http://localhost:3000

# --- Admin auth (single owner account; JWT + guard on /admin, no users table) ---
# Generate JWT_SECRET with: openssl rand -base64 32
JWT_SECRET=change-me-to-a-random-32-byte-string
JWT_EXPIRES_IN_SECONDS=604800
ADMIN_EMAIL=owner@softclubstore.local
# Generate with: node -e "console.log(require('bcrypt').hashSync('your-password', 10))" (run from apps/api)
# Wrap it in single quotes — the hash's $ characters otherwise trip docker
# compose's env-file variable interpolation (harmless but noisy warnings).
ADMIN_PASSWORD_HASH=''
